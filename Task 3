<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Restaurant Menu</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>

body{
    margin:0;
    font-family:Poppins;
    background:#0b1020;
    color:white;
}

header{
    text-align:center;
    padding:30px;
    background:linear-gradient(135deg,#7c4dff,#20d6ff);
}

header h1{
    margin:0;
    font-size:32px;
}

.container{
    max-width:1100px;
    margin:auto;
    padding:20px;
}

.categories{
    display:flex;
    gap:10px;
    justify-content:center;
    margin-bottom:20px;
}

.categories button{
    padding:10px 16px;
    border:none;
    border-radius:20px;
    cursor:pointer;
    background:#1e243a;
    color:white;
    font-weight:600;
}

.categories button.active{
    background:#7c4dff;
}

.menu{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.card{
    background:#151b30;
    padding:15px;
    border-radius:12px;
}

.card img{
    width:100%;
    border-radius:10px;
}

.card h3{
    margin:10px 0 5px;
}

.card p{
    font-size:14px;
    opacity:0.7;
}

.price{
    margin-top:8px;
    font-weight:700;
    color:#20d6ff;
}

.order{
    margin-top:10px;
    padding:8px 12px;
    border:none;
    border-radius:8px;
    cursor:pointer;
    background:#7c4dff;
    color:white;
}

.cart{
    margin-top:30px;
    padding:20px;
    background:#151b30;
    border-radius:12px;
}

</style>
</head>

<body>

<header>
<h1>Restaurant Menu</h1>
<p>Choose your favorite dishes</p>
</header>

<div class="container">

<div class="categories">
<button onclick="filterMenu('all')" class="active">All</button>
<button onclick="filterMenu('starter')">Starters</button>
<button onclick="filterMenu('main')">Main Course</button>
<button onclick="filterMenu('dessert')">Desserts</button>
<button onclick="filterMenu('drink')">Drinks</button>
</div>

<div class="menu" id="menu"></div>

<div class="cart">
<h3>Your Order</h3>
<ul id="cart"></ul>
<b>Total: ₹<span id="total">0</span></b>
</div>

</div>

<script>

const food=[
{cat:"starter",name:"Paneer Tikka",price:200,img:"https://picsum.photos/300?1",desc:"Grilled paneer with spices"},
{cat:"starter",name:"Chicken 65",price:220,img:"https://picsum.photos/300?2",desc:"Crispy spicy chicken"},
{cat:"main",name:"Chicken Biryani",price:300,img:"https://picsum.photos/300?3",desc:"Hyderabadi style biryani"},
{cat:"main",name:"Veg Fried Rice",price:180,img:"https://picsum.photos/300?4",desc:"Chinese style fried rice"},
{cat:"dessert",name:"Ice Cream",price:120,img:"https://picsum.photos/300?5",desc:"Vanilla ice cream"},
{cat:"dessert",name:"Gulab Jamun",price:100,img:"https://picsum.photos/300?6",desc:"Sweet syrup balls"},
{cat:"drink",name:"Cold Coffee",price:90,img:"https://picsum.photos/300?7",desc:"Iced coffee"},
{cat:"drink",name:"Lime Soda",price:70,img:"https://picsum.photos/300?8",desc:"Fresh lime drink"}
];

let cart=[];
let total=0;

function displayMenu(list){

const menu=document.getElementById("menu");
menu.innerHTML="";

list.forEach(item=>{

const card=document.createElement("div");
card.className="card";

card.innerHTML=`
<img src="${item.img}">
<h3>${item.name}</h3>
<p>${item.desc}</p>
<div class="price">₹${item.price}</div>
<button class="order" onclick="addToCart('${item.name}',${item.price})">Add to Cart</button>
`;

menu.appendChild(card);

});

}

function filterMenu(category){

document.querySelectorAll(".categories button").forEach(b=>b.classList.remove("active"));
event.target.classList.add("active");

if(category==="all") displayMenu(food);
else displayMenu(food.filter(i=>i.cat===category));

}

function addToCart(name,price){

cart.push({name,price});
total+=price;

const cartList=document.getElementById("cart");
const li=document.createElement("li");

li.textContent=name+" - ₹"+price;

cartList.appendChild(li);

document.getElementById("total").textContent=total;

}

displayMenu(food);

</script>

</body>
</html>
