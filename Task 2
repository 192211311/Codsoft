<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Task 2 • Email Template</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    :root{
      --bg:#0b1020;
      --card: rgba(255,255,255,0.06);
      --stroke: rgba(255,255,255,0.12);
      --text:#eef3ff;
      --muted: rgba(238,243,255,0.65);
      --brand:#7c4dff;
      --brand2:#20d6ff;
      --shadow: 0 20px 60px rgba(0,0,0,.45);
      --r: 22px;
    }
    *{box-sizing:border-box}
    body{
      margin:0; font-family:Poppins,system-ui,Segoe UI,Roboto,Arial;
      background: radial-gradient(900px 500px at 20% 10%, rgba(124,77,255,.35), transparent 60%),
                  radial-gradient(900px 500px at 80% 30%, rgba(32,214,255,.25), transparent 55%),
                  var(--bg);
      color:var(--text);
      min-height:100vh;
      display:flex; align-items:center; justify-content:center;
      padding:24px;
    }
    .wrap{
      width:min(1100px, 100%);
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap:16px;
    }
    @media (max-width: 980px){ .wrap{grid-template-columns:1fr} }

    .panel{
      background: var(--card);
      border:1px solid var(--stroke);
      border-radius: var(--r);
      box-shadow: var(--shadow);
      overflow:hidden;
    }
    .head{
      padding:16px 18px;
      border-bottom:1px solid var(--stroke);
      display:flex; justify-content:space-between; align-items:center;
      gap:12px;
    }
    .title{font-weight:900}
    .tiny{font-size:12px; color:var(--muted)}
    .body{padding:18px}

    label{display:block; font-size:12px; color:var(--muted); margin:12px 0 6px}
    input, textarea{
      width:100%;
      padding:12px 12px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,0.14);
      background: rgba(255,255,255,0.06);
      color: var(--text);
      outline:none;
      font-family:inherit;
    }
    textarea{min-height:130px; resize:vertical}

    .btnRow{display:flex; gap:10px; margin-top:14px; flex-wrap:wrap}
    button{
      flex:1;
      border:none;
      border-radius:14px;
      padding:12px 14px;
      font-weight:900;
      cursor:pointer;
      background: rgba(255,255,255,0.10);
      color: var(--text);
      border:1px solid rgba(255,255,255,0.14);
    }
    button.primary{
      border:none;
      background: linear-gradient(135deg, var(--brand), var(--brand2));
      color:#061021;
    }
    .toast{
      margin-top:10px;
      font-size:12px;
      color: rgba(214,255,240,.9);
      display:none;
      padding:10px 12px;
      border-radius:14px;
      border:1px solid rgba(24,255,155,0.25);
      background: rgba(24,255,155,0.10);
    }

    /* Email preview */
    .email{padding:18px}
    .mailBox{
      border-radius:18px;
      border:1px solid var(--stroke);
      background: rgba(0,0,0,0.25);
      overflow:hidden;
    }
    .hero{
      padding:22px 20px;
      background: linear-gradient(135deg, rgba(124,77,255,.85), rgba(32,214,255,.65));
      color:#061021;
    }
    .hero .brandLine{font-weight:900; letter-spacing:.2px}
    .hero h1{margin:6px 0 6px; font-size:22px; line-height:1.2}
    .hero p{margin:0; opacity:.85}

    .content{padding:18px 18px 14px}
    .content h2{margin:0 0 10px; font-size:16px}
    .content p{margin:0 0 10px; color:var(--muted); line-height:1.6}

    .cta{
      display:inline-block;
      margin:10px 0 0;
      padding:11px 14px;
      border-radius:12px;
      background: rgba(255,255,255,0.10);
      border:1px solid rgba(255,255,255,0.18);
      color: var(--text);
      text-decoration:none;
      font-weight:900;
    }
    .footer{
      padding:14px 18px;
      border-top:1px solid var(--stroke);
      color:rgba(238,243,255,0.55);
      font-size:12px;
      display:flex;
      justify-content:space-between;
      flex-wrap:wrap;
      gap:8px;
    }
    .mono{
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      font-size:12px;
      color: rgba(238,243,255,0.75);
      white-space: pre-wrap;
      word-break: break-word;
      border-radius:16px;
      border:1px dashed rgba(255,255,255,0.18);
      padding:12px;
      background: rgba(255,255,255,0.03);
      display:none;
      margin-top:12px;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <!-- Builder -->
    <div class="panel">
      <div class="head">
        <div class="title">Task 2 • Email Template Builder</div>
        <div class="tiny">Visually appealing • Responsive</div>
      </div>

      <div class="body">
        <label>Company / Brand</label>
        <input id="brand" value="DietHive"/>

        <label>Headline</label>
        <input id="headline" value="Your weekly update is here 🚀"/>

        <label>Greeting Name (optional)</label>
        <input id="person" value="Chotu"/>

        <label>Main Message</label>
        <textarea id="msg">Hi! Here’s a quick update on what’s new this week. We improved the UI, added smoother tracking, and introduced personalized tips to keep you consistent.</textarea>

        <label>Button Text</label>
        <input id="btnText" value="Explore Updates"/>

        <label>Button Link</label>
        <input id="btnLink" value="https://example.com"/>

        <label>Footer Note</label>
        <input id="foot" value="You received this email because you signed up for updates."/>

        <div class="btnRow">
          <button class="primary" id="copyBtn">Copy Email HTML</button>
          <button id="viewSourceBtn">View HTML Source</button>
        </div>

        <div class="toast" id="toast">Copied ✅ Paste into your email tool.</div>
        <div class="mono" id="src"></div>
      </div>
    </div>

    <!-- Preview -->
    <div class="panel">
      <div class="head">
        <div class="title">Live Preview</div>
        <div class="tiny">Desktop + Mobile friendly</div>
      </div>

      <div class="email">
        <div class="mailBox" id="preview">
          <div class="hero">
            <div class="brandLine" id="pBrand">DietHive</div>
            <h1 id="pHead">Your weekly update is here 🚀</h1>
            <p>Simple. Professional. Engaging.</p>
          </div>

          <div class="content">
            <h2 id="pHello">Hello 👋</h2>
            <p id="pMsg"></p>
            <a class="cta" id="pBtn" href="#" target="_blank" rel="noreferrer">Explore Updates</a>
            <p style="margin-top:12px;">If you have questions, just reply to this email.</p>
          </div>

          <div class="footer">
            <span id="pFoot">You received this email because you signed up for updates.</span>
            <span>© <span id="yr"></span> <span id="pBrand2">DietHive</span></span>
          </div>
        </div>
      </div>
    </div>
  </div>

<script>
  const $ = (id)=>document.getElementById(id);

  function escapeHtml(str){
    return String(str)
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#039;");
  }

  function render(){
    const brand = $("brand").value.trim() || "Brand";
    const headline = $("headline").value.trim() || "Headline";
    const person = $("person").value.trim();
    const msg = $("msg").value.trim() || "Message...";
    const btnText = $("btnText").value.trim() || "Button";
    const btnLink = $("btnLink").value.trim() || "#";
    const foot = $("foot").value.trim();

    $("pBrand").textContent = brand;
    $("pBrand2").textContent = brand;
    $("pHead").textContent = headline;
    $("pHello").textContent = person ? `Hello, ${person} 👋` : "Hello 👋";
    $("pMsg").textContent = msg;
    $("pBtn").textContent = btnText;
    $("pBtn").href = btnLink;
    $("pFoot").textContent = foot;
    $("yr").textContent = new Date().getFullYear();

    // source HTML (for copying into marketing tools)
    const html = `
<div style="font-family:Poppins,Arial,sans-serif;background:#0b1020;padding:20px;color:#eef3ff">
  <div style="max-width:600px;margin:0 auto;border:1px solid rgba(255,255,255,0.12);border-radius:18px;overflow:hidden;background:rgba(0,0,0,0.25)">
    <div style="padding:22px 20px;background:linear-gradient(135deg, rgba(124,77,255,.85), rgba(32,214,255,.65));color:#061021">
      <div style="font-weight:800">${escapeHtml(brand)}</div>
      <div style="font-size:22px;font-weight:800;line-height:1.2;margin-top:6px">${escapeHtml(headline)}</div>
      <div style="opacity:.85;margin-top:6px">Simple. Professional. Engaging.</div>
    </div>
    <div style="padding:18px 18px 14px">
      <div style="font-size:16px;font-weight:700;margin-bottom:10px">${escapeHtml(person ? `Hello, ${person} 👋` : "Hello 👋")}</div>
      <div style="color:rgba(238,243,255,0.75);line-height:1.6;margin-bottom:12px">${escapeHtml(msg)}</div>
      <a href="${escapeHtml(btnLink)}" style="display:inline-block;padding:11px 14px;border-radius:12px;border:1px solid rgba(255,255,255,0.18);background:rgba(255,255,255,0.10);color:#eef3ff;text-decoration:none;font-weight:800">${escapeHtml(btnText)}</a>
      <div style="color:rgba(238,243,255,0.65);margin-top:14px">If you have questions, just reply to this email.</div>
    </div>
    <div style="padding:14px 18px;border-top:1px solid rgba(255,255,255,0.12);color:rgba(238,243,255,0.55);font-size:12px;display:flex;justify-content:space-between;gap:8px;flex-wrap:wrap">
      <span>${escapeHtml(foot)}</span>
      <span>© ${new Date().getFullYear()} ${escapeHtml(brand)}</span>
    </div>
  </div>
</div>`.trim();

    $("src").textContent = html;
  }

  ["brand","headline","person","msg","btnText","btnLink","foot"].forEach(id=>{
    $(id).addEventListener("input", render);
  });

  $("copyBtn").addEventListener("click", async ()=>{
    try{
      await navigator.clipboard.writeText($("src").textContent);
      $("toast").style.display="block";
      setTimeout(()=> $("toast").style.display="none", 1300);
    }catch(e){
      alert("Clipboard blocked. Click 'View HTML Source' and copy manually.");
    }
  });

  $("viewSourceBtn").addEventListener("click", ()=>{
    const s = $("src");
    s.style.display = (s.style.display==="none" || !s.style.display) ? "block" : "none";
  });

  render();
</script>
</body>
</html>
